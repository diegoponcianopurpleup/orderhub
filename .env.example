# Banco local (dev)
# DATABASE_URL="file:./dev.db"

# Banco de producao (ex.: PostgreSQL gerenciado)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

APP_NAME="OrderHub Core"
APP_URL="http://localhost:3000"

# OBRIGATORIO em producao: minimo 32 caracteres, nao use valor padrao
SESSION_SECRET="change-me-in-production-with-at-least-32-characters"

BILLING_ENABLED="false"
BILLING_PROVIDER="mock"
